<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?> <?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="530.0" prefWidth="420.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafinal.FXMLDocumentController">
    <children>
        <Label layoutX="40.0" layoutY="20.0" text="Gestión de Vehículos - UTN">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        
        <Label layoutX="40.0" layoutY="75.0" text="Patente:" />
        <TextField fx:id="txtPatente" layoutX="110.0" layoutY="70.0" prefWidth="270.0" />
        
        <Label layoutX="40.0" layoutY="115.0" text="Marca:" />
        <TextField fx:id="txtMarca" layoutX="110.0" layoutY="110.0" prefWidth="270.0" />
        
        <Label layoutX="40.0" layoutY="155.0" text="Tipo:" />
        <ComboBox fx:id="cmbTipo" layoutX="110.0" layoutY="150.0" prefWidth="270.0" promptText="Seleccione Tipo" />
        
        <Button fx:id="btnAgregar" layoutX="40.0" layoutY="195.0" onAction="#handleAgregarAction" prefWidth="105.0" text="Agregar" />
        <Button fx:id="btnActualizar" layoutX="157.0" layoutY="195.0" onAction="#handleActualizarAction" prefWidth="105.0" text="Actualizar" />
        <Button fx:id="btnEliminar" layoutX="275.0" layoutY="195.0" onAction="#handleEliminarAction" prefWidth="105.0" text="Eliminar" />
        
        <Button fx:id="btnListar" layoutX="40.0" layoutY="240.0" onAction="#handleListarAction" prefWidth="105.0" text="Listar Todo" />
        <Button fx:id="btnOrdenar" layoutX="157.0" layoutY="240.0" onAction="#handleOrdenarAction" prefWidth="105.0" text="Ord. por Marca" />
        <Button fx:id="btnFiltrar" layoutX="275.0" layoutY="240.0" onAction="#handleFiltrarAction" prefWidth="105.0" text="Filtrar" />
        
        <TextArea fx:id="txtAreaLista" editable="false" layoutX="40.0" layoutY="290.0" prefHeight="180.0" prefWidth="340.0" wrapText="true" />
        
        <Label fx:id="lblMensajes" layoutX="40.0" layoutY="490.0" prefWidth="340.0" text="Estado: Esperando acciones..." textFill="#555555">
            <font>
                <Font name="System Italic" size="12.0" />
            </font>
        </Label>
    </children>
</AnchorPane>